FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    build-essential \
    libpcap-dev \
    curl \
    git \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

COPY pwnagotchi /app/pwnagotchi
COPY tools/parity/compose/jayofelony_runner.py /app/runner.py

RUN pip install --no-cache-dir \
    tornado \
    requests \
    pillow \
    pyyaml \
    toml \
    aiohttp

EXPOSE 8080

CMD ["python3", "/app/runner.py"]
