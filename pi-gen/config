#!/bin/bash
# PWNGHOST-RS pi-gen build configuration.
#
# This is sourced by build.sh near the top (before the rest of build.sh's own
# `export FOO=${FOO:-default}` lines run), so anything we want visible to
# stage scripts (which run as separate child processes) must be `export`ed
# here explicitly - build.sh only re-exports the upstream pi-gen vars it
# already knows about, not ours.

# --- Board / target-arch selection ---------------------------------------
# Set by CI as an env var before invoking build.sh (see
# .github/workflows/release.yml, matrix.board), or manually for a local
# build. Drives which pre-built Rust artifact (stage4) and which AngryOxide
# release tarball (stage4) get installed into the image.
#   pi-zero-w  -> Pi Zero W,  BCM2835, ARMv6 (arm1176jzf-s)
#   pi-zero-2w -> Pi Zero 2W, BCM2710A1, ARMv7 (cortex-a53)
export PWNGHOST_BOARD="${PWNGHOST_BOARD:-pi-zero-2w}"

case "${PWNGHOST_BOARD}" in
	pi-zero-w)
		export RUST_TARGET_TRIPLE="arm-unknown-linux-gnueabihf"
		export ANGRYOXIDE_ARCH="linux-arm-musl"
		;;
	pi-zero-2w)
		export RUST_TARGET_TRIPLE="armv7-unknown-linux-gnueabihf"
		export ANGRYOXIDE_ARCH="linux-armv7hf-musl"
		;;
	*)
		echo "config: unknown PWNGHOST_BOARD='${PWNGHOST_BOARD}' (expected 'pi-zero-w' or 'pi-zero-2w')" >&2
		exit 1
		;;
esac

# Pinned AngryOxide release (Ragnt/AngryOxide). Bump deliberately.
export ANGRYOXIDE_VERSION="${ANGRYOXIDE_VERSION:-v0.9.2}"

# stage3 nexmon: build the BCM43436B0 (Pi Zero 2W chip) injection-firmware
# patch. Default on; set to 0 if hardware validation reproduces the SDIO
# instability noted in stage3/00-kernel-nexmon/00-run.sh's header comment.
export PWNGHOST_ENABLE_BCM43436B0_PATCH="${PWNGHOST_ENABLE_BCM43436B0_PATCH:-1}"

# --- pi-gen base -----------------------------------------------------------
export RELEASE="bookworm"

export IMG_NAME="${IMG_NAME:-pwnghost-rs-${PWNGHOST_BOARD}}"
export DEPLOY_COMPRESSION="xz"

export TARGET_HOSTNAME="pwnghost"
# Matches jayofelony/pwnagotchi's actual default login (verified by reading
# their cloud-init user-data file) rather than a custom scheme, for
# drop-in-replacement fidelity -- real pwnagotchi users expect pi/raspberry.
# Unlike that reference image, sudo here still requires the password (see
# stage2/04-pwnghost-base's note) since there's no first-boot wizard
# prompting a password change.
export FIRST_USER_NAME="pi"
export FIRST_USER_PASS="raspberry"
# We ship a fixed default user/password for a headless SD-card image (like
# upstream pwnagotchi images); skip pi-gen's interactive first-boot rename.
export DISABLE_FIRST_BOOT_USER_RENAME=1

export ENABLE_SSH=1
export PUBKEY_ONLY_SSH=0

export LOCALE_DEFAULT="en_US.UTF-8"
export KEYBOARD_KEYMAP="us"
export KEYBOARD_LAYOUT="English (US)"
export TIMEZONE_DEFAULT="Etc/UTC"

# No cloud-init / desktop / NOOBS extras for this headless image.
export ENABLE_CLOUD_INIT=0
